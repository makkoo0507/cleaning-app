# LIFF（LINE Mini App）
# 値は NEXT_PUBLIC_ なので公開値（秘密情報ではない）。
# ローカル: テスト用 LIFF（エンドポイント=ローカルのHTTPSトンネル）の ID を入れる。空でもビルドは可。
#   ※本番用 LIFF はコールバックが本番ドメイン向けのため、ローカルでは動かない。
# 本番: 下記の本番 LIFF ID を Vercel の環境変数に設定する。
#   NEXT_PUBLIC_LIFF_ID_CLEANER=2010463195-prlgJV64   （清掃者用・/liff/cleaner）
#   NEXT_PUBLIC_LIFF_ID_OWNER=2010463195-NIUZjGjX     （オーナー用・/liff/owner）
NEXT_PUBLIC_LIFF_ID_CLEANER=
NEXT_PUBLIC_LIFF_ID_OWNER=
